# ──────────────────────────────────────────────────────────────────────
# Toke — environment configuration
# ──────────────────────────────────────────────────────────────────────
# Copy this to .env and customize. Hooks + scripts read these at runtime.
# If TOKE_ROOT is unset, the user's historical layout is assumed
# ($HOME/Desktop/T1/Toke). Set it on any other clone.

# Where the repo lives. Required for portable clones.
# Linux/macOS example:  TOKE_ROOT=/home/you/code/toke
# Windows (Git Bash):   TOKE_ROOT=/c/Users/you/code/toke
# Windows (cmd.exe):    set TOKE_ROOT=C:\Users\you\code\toke
TOKE_ROOT=/your/path/to/toke

# Brain Zone 2 subagent routing. Every Agent tool call inherits this model.
# Default is sonnet; don't change unless you want every subagent on Opus.
CLAUDE_CODE_SUBAGENT_MODEL=sonnet

# Required for `brain advise` (Sybil L4 advisor escalation API calls).
# Leave blank to disable advisor escalation.
ANTHROPIC_API_KEY=

# Optional: local Qwen 2.5 14B via Ollama for S0-S2 factual lookups.
# Zero API cost, 9-30s latency. Falls through to Claude if Ollama offline.
OLLAMA_HOST=http://127.0.0.1:11434
